# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

CI_DEBUG = false


# Polaris API
POLARIS_BASE_URL=http://41.203.191.15/api/polaris
POLARIS_API_TOKEN=dad1505aec32a71941f146fd5aaf9081
POLARIS_TIMEOUT=30
POLARIS_CONNECT_TIMEOUT=10
POLARIS_VERIFY_SSL=true
POLARIS_PAGE_SIZE=500
POLARIS_MAX_RETRIES=3
POLARIS_RETRY_DELAY=5

